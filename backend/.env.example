# Environment
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True

# Database (set USE_POSTGRES=True to use PostgreSQL instead of SQLite)
USE_POSTGRES=False
DB_NAME=ai_repair_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_HOST=localhost
DB_PORT=5432

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# CORS
CORS_ALLOW_ALL_ORIGINS=True
